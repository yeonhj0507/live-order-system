{
  "name": "live-order-system",
  "version": "1.0.0",
  "description": "인스타그램 라이브 커머스 주문 관리 시스템",
  "private": true,
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "node server/app.js",
    "start": "node server/app.js",
    "client": "cd client && npx vite --port 5173",
    "db:init": "node server/db-init.js",
    "build": "cd client && npm install && npx vite build"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "express": "^4.21.0",
    "mysql2": "^3.11.0",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "concurrently": "^9.0.0"
  }
}
